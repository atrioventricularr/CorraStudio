# ============================================
# CORRA STUDIO - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# Supabase (Cloud Storage) - REQUIRED
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_BUCKET=corra-gallery

# Mayar License - REQUIRED
MAYAR_API_KEY=your-mayar-api-key
MAYAR_API_URL=https://api.mayar.id/v1
MAYAR_PRODUCTION=false

# Web Gallery URL
GALLERY_URL=https://your-gallery.netlify.app

# Update Server (optional)
UPDATE_URL=https://updates.corrastudio.com
