<Page x:Class="CorraStudio.Presentation.Wpf.Views.CompletePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource SuccessBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="1">
            <TextBlock Text="✨" FontSize="72" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Message}" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,20"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20">
            <Button Content="NEW SESSION" 
                    Style="{StaticResource SuccessButton}"
                    Width="200"
                    Height="50"
                    Command="{Binding NewSessionCommand}"/>
            <Button Content="PRINT AGAIN" 
                    Style="{StaticResource SecondaryButton}"
                    Width="200"
                    Height="50"
                    Command="{Binding PrintAgainCommand}"
                    Margin="10,0"/>
            <Button Content="EXIT" 
                    Style="{StaticResource DangerButton}"
                    Width="150"
                    Height="50"
                    Command="{Binding ExitCommand}"
                    Margin="10,0"/>
        </StackPanel>
        
        <!-- QR Code Section -->
        <Border Grid.Row="3" 
                Background="White" 
                CornerRadius="10"
                Width="200"
                Height="200"
                HorizontalAlignment="Center"
                Margin="0,20"
                Visibility="{Binding ShowDownloadOptions, Converter={StaticResource BoolToVisibilityConverter}}">
            <Image Source="{Binding QrCode}" Stretch="Uniform"/>
        </Border>
    </Grid>
</Page>
