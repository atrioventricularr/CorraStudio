<Page x:Class="CorraStudio.Presentation.Wpf.Views.ReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource Gray100Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <TextBlock Text="📸 REVIEW YOUR PHOTOS" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
        
        <!-- Photo Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Photos}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="20" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" 
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThickness}}"
                                CornerRadius="5"
                                Cursor="Hand">
                            <Image Source="{Binding Image}" 
                                   Width="200" 
                                   Height="200" 
                                   Stretch="UniformToFill"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Border Grid.Row="2" Background="{StaticResource Gray200Brush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedCount, StringFormat='Selected: {0} photos'}" 
                           Style="{StaticResource BodyText}"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <Button Content="RETAKE" 
                        Style="{StaticResource WarningButton}"
                        Command="{Binding RetakeCommand}"/>
                <Button Content="PRINT" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding PrintCommand}"
                        IsEnabled="{Binding HasSelectedPhotos}"/>
                <Button Content="CONTINUE TO PAYMENT" 
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding ContinueToPaymentCommand}"
                        IsEnabled="{Binding HasSelectedPhotos}"/>
                <Button Content="CANCEL" 
                        Style="{StaticResource DangerButton}"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
