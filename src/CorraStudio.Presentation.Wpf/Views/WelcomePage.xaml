<Page x:Class="CorraStudio.Presentation.Wpf.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Welcome">
    
    <Grid Background="{StaticResource PrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="1" Margin="0,50">
            <TextBlock Text="📸 CORRA STUDIO" 
                       FontSize="48" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Professional Photobooth Software"
                       FontSize="24"
                       Foreground="#DDDDDD"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
            <Button Content="START SESSION" 
                    Style="{StaticResource SuccessButton}"
                    Width="300"
                    Height="60"
                    FontSize="20"
                    Command="{Binding StartCommand}"/>
            <Button Content="Settings" 
                    Style="{StaticResource OutlineButton}"
                    Width="200"
                    Height="40"
                    Margin="0,10"
                    Command="{Binding SettingsCommand}"/>
            <Button Content="Admin Panel" 
                    Style="{StaticResource SecondaryButton}"
                    Width="200"
                    Height="40"
                    Command="{Binding AdminCommand}"/>
        </StackPanel>
    </Grid>
</Page>
