<Page x:Class="CorraStudio.Presentation.Wpf.Views.Admin.Settings.ThemeSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Theme Settings"
      Background="{StaticResource Gray100Brush}">
    
    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Theme Presets -->
            <Border Grid.Row="0" Background="{StaticResource Gray200Brush}" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🎨 Theme Presets" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    
                    <ItemsControl ItemsSource="{Binding AvailableThemes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="150" Height="120" Margin="10" 
                                        Background="{Binding PrimaryColor, Converter={StaticResource StringToBrushConverter}}"
                                        CornerRadius="10"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Page}}" 
                                                      CommandParameter="{Binding}" 
                                                      Gesture="LeftClick"/>
                                    </Border.InputBindings>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ThemeName}" 
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Border Background="White" CornerRadius="3" Margin="0,10,0,0" Padding="5,2">
                                            <TextBlock Text="Apply" FontSize="10" Foreground="{Binding PrimaryColor}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
            <!-- Branding -->
            <Border Grid.Row="1" Background="{StaticResource Gray200Brush}" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🏷️ Branding" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Brand Name" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BrandName}" Width="300" HorizontalAlignment="Left"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Logo" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="{Binding LogoPath}" FontSize="11" Foreground="{StaticResource Gray600Brush}" 
                                       VerticalAlignment="Center" Width="200" TextTrimming="CharacterEllipsis"/>
                            <Button Content="Browse" Command="{Binding SelectLogoCommand}" Margin="10,0,0,0" Width="70"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Colors -->
            <Border Grid.Row="2" Background="{StaticResource Gray200Brush}" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🎨 Colors" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Primary Color" VerticalAlignment="Center"/>
                        <Border Grid.Row="0" Grid.Column="1" Width="50" Height="30" CornerRadius="5">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding PrimaryColor, Converter={StaticResource StringToColorConverter}}"/>
                            </Border.Background>
                        </Border>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Secondary Color" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <Border Grid.Row="1" Grid.Column="1" Width="50" Height="30" CornerRadius="5" Margin="0,10,0,0">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding SecondaryColor, Converter={StaticResource StringToColorConverter}}"/>
                            </Border.Background>
                        </Border>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Accent Color" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <Border Grid.Row="2" Grid.Column="1" Width="50" Height="30" CornerRadius="5" Margin="0,10,0,0">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding AccentColor, Converter={StaticResource StringToColorConverter}}"/>
                            </Border.Background>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Background -->
            <Border Grid.Row="3" Background="{StaticResource Gray200Brush}" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🖼️ Background" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding BackgroundPath}" FontSize="11" Foreground="{StaticResource Gray600Brush}" 
                                   VerticalAlignment="Center" Width="300" TextTrimming="CharacterEllipsis"/>
                        <Button Content="Browse" Command="{Binding SelectBackgroundCommand}" Margin="10,0,0,0" Width="70"/>
                        <Button Content="Clear" Command="{Binding ClearBackgroundCommand}" Margin="10,0,0,0" Width="70"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Advanced Settings -->
            <Border Grid.Row="4" Background="{StaticResource Gray200Brush}" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ Advanced" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    
                    <CheckBox Content="Enable Animations (stars, hearts, transitions)" 
                              IsChecked="{Binding EnableAnimations}" Margin="0,5"/>
                    <CheckBox Content="Enable Sound Effects" 
                              IsChecked="{Binding EnableSoundEffects}" Margin="0,5"/>
                    
                    <TextBlock Text="Font Family" Margin="0,15,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableFonts}" 
                              SelectedItem="{Binding FontFamily}" Width="250" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <!-- Preview & Actions -->
            <Border Grid.Row="5" Padding="15" CornerRadius="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Preview" 
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding PreviewCommand}"
                            Width="100"
                            Margin="5"/>
                    <Button Content="Save Theme" 
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding SaveSettingsCommand}"
                            Width="120"
                            Margin="5"/>
                    <Button Content="Reset to Default" 
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ResetCommand}"
                            Width="120"
                            Margin="5"/>
                </StackPanel>
            </Border>
            
            <!-- Status -->
            <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" 
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,20"/>
        </Grid>
    </ScrollViewer>
</Page>
