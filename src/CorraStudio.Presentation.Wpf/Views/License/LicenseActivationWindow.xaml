<Window x:Class="CorraStudio.Presentation.Wpf.Views.License.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activate Corra Studio" 
        Height="500" 
        Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    
    <Grid Background="{StaticResource Gray100Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="30">
            <StackPanel>
                <TextBlock Text="📸 Corra Studio" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Professional Photobooth Software" 
                           FontSize="14" 
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="40" VerticalAlignment="Center">
            
            <!-- License Code Input -->
            <TextBlock Text="License Code" 
                       FontWeight="Bold" 
                       Margin="0,0,0,5"/>
            <TextBox Text="{Binding LicenseCode}" 
                     Height="40"
                     FontSize="16"
                     FontFamily="Consolas"
                     Padding="10"
                     Margin="0,0,0,15"
                     HorizontalContentAlignment="Center"
                     GotFocus="TextBox_GotFocus"/>
            
            <!-- Email (Optional) -->
            <TextBlock Text="Email (optional)" 
                       FontWeight="Bold" 
                       Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email}" 
                     Height="35"
                     Padding="10"
                     Margin="0,0,0,20"/>
            
            <!-- Status Message -->
            <Border Background="{StaticResource Gray200Brush}" 
                    CornerRadius="5" 
                    Padding="10"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="ℹ️ How to get your license"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="1. Purchase license from mayar.id/corra-studio"
                               FontSize="12"
                               Margin="0,2"/>
                    <TextBlock Text="2. Copy the license code from your email"
                               FontSize="12"
                               Margin="0,2"/>
                    <TextBlock Text="3. Paste it above and click Activate"
                               FontSize="12"
                               Margin="0,2"/>
                </StackPanel>
            </Border>
            
            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="{Binding HasError, Converter={StaticResource ErrorColorConverter}}"
                       TextAlignment="Center"
                       Margin="0,10"/>
        </StackPanel>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource Gray200Brush}" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Activate" 
                        Style="{StaticResource SuccessButton}"
                        Width="120"
                        Height="40"
                        Command="{Binding ActivateCommand}"
                        IsEnabled="{Binding CanActivate}"
                        Margin="5"/>
                <Button Content="Close" 
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Height="40"
                        Command="{Binding CloseCommand}"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
