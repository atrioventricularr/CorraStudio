<Page x:Class="CorraStudio.Presentation.Wpf.Views.ProcessingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource Gray100Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="1" Margin="50">
            <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Status}" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,20"/>
            
            <ProgressBar Value="{Binding ProgressPercentage}" 
                         Height="20"
                         Width="400"
                         Margin="0,20"/>
            
            <TextBlock Text="{Binding CurrentTask}" 
                       FontSize="14"
                       Foreground="{StaticResource Gray600Brush}"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>
            
            <Button Content="CANCEL" 
                    Style="{StaticResource DangerButton}"
                    Width="150"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,20"/>
        </StackPanel>
    </Grid>
</Page>
