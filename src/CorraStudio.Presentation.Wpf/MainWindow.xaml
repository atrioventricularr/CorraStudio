<Window x:Class="CorraStudio.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" 
        Height="768" 
        Width="1024"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="False">
    
    <DockPanel>
        <!-- Top Navigation Bar -->
        <Border DockPanel.Dock="Top" 
                Height="50" 
                Background="{StaticResource PrimaryDarkBrush}"
                Visibility="{Binding IsNavigationBarVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            
            <DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="{Binding Title}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPageTitle}" 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="◀" 
                            Style="{StaticResource SecondaryButton}"
                            Width="40" 
                            Height="30"
                            Command="{Binding GoBackCommand}"
                            Margin="5"
                            IsEnabled="{Binding CanGoBack}"/>
                    <Button Content="▶" 
                            Style="{StaticResource SecondaryButton}"
                            Width="40" 
                            Height="30"
                            Command="{Binding GoForwardCommand}"
                            Margin="5"
                            IsEnabled="{Binding CanGoForward}"/>
                    <Button Content="✕" 
                            Style="{StaticResource DangerButton}"
                            Width="40" 
                            Height="30"
                            Command="{Binding ExitCommand}"
                            Margin="10,5,20,5"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- Main Content Frame -->
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        
        <!-- Busy Overlay -->
        <Border Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading..." FontSize="20" Foreground="White" HorizontalAlignment="Center" Margin="0,10"/>
            </StackPanel>
        </Border>
        
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" 
                Height="30" 
                Background="{StaticResource Gray200Brush}">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" 
                           Style="{StaticResource BodyText}"
                           VerticalAlignment="Center"
                           Margin="10,0"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </DockPanel>
</Window>
