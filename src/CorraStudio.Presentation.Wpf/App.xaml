<Application x:Class="CorraStudio.Presentation.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Base Styles -->
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/TextStyles.xaml"/>
                <ResourceDictionary Source="Styles/ControlStyles.xaml"/>
                
                <!-- Y2K Theme (Default) -->
                <ResourceDictionary Source="Styles/MomoTheme.xaml"/>
                <ResourceDictionary Source="Styles/MomoButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Theme-aware dynamic resources -->
            <SolidColorBrush x:Key="DynamicPrimaryBrush" Color="{Binding Source={x:Static Application.Current}, Path=Resources.MomoPinkColor, Mode=OneWay}"/>
            
            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
            <converters:ThicknessConverter x:Key="BoolToThickness"/>
            <converters:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter"/>
            <converters:StepToVisibilityConverter x:Key="StepToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
            <converters:BoolToCommandConverter x:Key="BoolToCommandConverter"/>
            <converters:StringToColorConverter x:Key="StringToColorConverter"/>
            <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
            
            <!-- Fonts -->
            <FontFamily x:Key="ThemeFontFamily">Comic Sans MS, Segoe UI</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
